{
  "query": {
    "bool": {
      "minimum_should_match": 1,
      "should": [
        {
          "nested": {
            "path": "albums",
            "query": {
              "bool": {
                "filter": [
                  {
                    "term": {
                      "albums.type": "Vinyl"
                    }
                  }
                ],
                "must": [
                  {
                    "bool": {
                      "minimum_should_match": 1,
                      "should": [
                        {
                          "match_phrase": {
                            "albums.album": {
                              "query": "poop",
                              "slop": 2,
                              "boost": 6
                            }
                          }
                        },
                        {
                          "match": {
                            "albums.album": {
                              "query": "poop",
                              "fuzziness": "AUTO",
                              "prefix_length": 2,
                              "max_expansions": 50,
                              "minimum_should_match": "3<75%",
                              "boost": 2
                            }
                          }
                        }
                      ]
                    }
                  }
                ]
              }
            }
          }
        },
        {
          "nested": {
            "path": "artists",
            "query": {
              "match": {
                "artists.artist": {
                  "query": "d",
                  "fuzziness": "AUTO",
                  "prefix_length": 1
                }
              }
            }
          }
        },
        {
          "match": {
            "custom": {
              "query": "pinpanteress heavn",
              "fuzziness": "AUTO",
              "minimum_should_match": "2<75%"
            }
          }
        },

        {
          "term": {
            "genres": "R&B"
          }
        },

        {
          "term": {
            "genres": "Pop"
          }
        }
      ]
    }
  }
}
